{
  "manifest_version": 3,
  "name": "Intext Reader",
  "version": "1.3.0",
  "description": "A local Chrome extension that embeds private reading text into selected webpage text.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "24": "icons/icon-24.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "24": "icons/icon-24.png",
      "32": "icons/icon-32.png"
    },
    "default_title": "Intext Reader",
    "default_popup": "src/popup.html"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/readingText.js",
        "src/epubModel.js",
        "src/illustrationMarkers.js",
        "src/readingRange.js",
        "src/illustrationOverlay.js",
        "src/i18n.js",
        "src/pageControl.js",
        "src/displayMode.js",
        "src/textFitting.js",
        "src/shortcuts.js",
        "src/interactionPolicy.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "intext-insert": {
      "suggested_key": {
        "default": "Alt+I"
      },
      "description": "Insert current reading page after selected text"
    },
    "intext-previous": {
      "suggested_key": {
        "default": "Alt+J"
      },
      "description": "Show previous reading page"
    },
    "intext-next": {
      "suggested_key": {
        "default": "Alt+K"
      },
      "description": "Show next reading page"
    },
    "intext-restore": {
      "suggested_key": {
        "default": "Alt+R"
      },
      "description": "Remove inserted reading text"
    },
    "intext-hide": {
      "description": "Scroll the page to hide inserted reading text"
    }
  }
}
